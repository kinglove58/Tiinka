<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Redirect HTTP to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect www to non-www (keep HTTPS)
RewriteCond %{HTTP_HOST} ^www\.tinkahealthservices\.com [NC]
RewriteRule ^(.*)$ https://tinkahealthservices.com/$1 [L,R=301]

# Redirect legacy booking route to canonical booking URL
RewriteCond %{REQUEST_URI} ^/tinkahealthservicesbooking/?$ [NC]
RewriteRule ^(.*)$ https://tinkahealthservices.com/booking [L,R=301]

# Redirect all requests to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# Serve static assets directly
<FilesMatch "\.(html|js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$">
  Header set Cache-Control "max-age=31536000, public"
</FilesMatch>

# Handle 404 errors
ErrorDocument 404 /index.html
</IfModule>